# ============================================================================
# Open Pincery — Operator Configuration
# Copy this file to `.env` and edit values marked REQUIRED.
# Docker Compose reads this file via ${VAR} interpolation in docker-compose.yml.
# For "From Source" runs, `source .env` before launching the binary.
# ============================================================================

# --- Database --------------------------------------------------------------
# For `docker compose up`: the app container uses an internal URL and ignores
# this. For `cargo run` / release binary: point at your Postgres instance.
DATABASE_URL=postgres://open_pincery:open_pincery@localhost:5432/open_pincery

# --- Server bind address ---------------------------------------------------
# For Docker Compose, keep 0.0.0.0 so the process is reachable from the
# container network; host exposure is still restricted by the port mapping
# "127.0.0.1:8080:8080" in docker-compose.yml.
# For bare-metal/source runs, set OPEN_PINCERY_HOST=127.0.0.1 if you only want
# local loopback access.
OPEN_PINCERY_HOST=0.0.0.0
OPEN_PINCERY_PORT=8080

# --- Bootstrap token (REQUIRED) --------------------------------------------
# Shared secret for POST /api/bootstrap on first run. Pick a long random value.
#   Linux/macOS:  openssl rand -hex 32
#   Windows PS:   -join ((48..57)+(97..102) | Get-Random -Count 64 | % {[char]$_})
OPEN_PINCERY_BOOTSTRAP_TOKEN=change-me-to-a-random-secret

# --- Credential vault master key (REQUIRED, v7) ----------------------------
# Base64-encoded 32-byte key used by the AES-256-GCM credential vault. Every
# workspace-scoped credential is sealed under this key. Generate once per
# deployment and NEVER rotate in place (v7) — v8 adds a re-wrap path.
#   Linux/macOS:  openssl rand -base64 32
#   Windows PS:   [Convert]::ToBase64String((1..32 | % {Get-Random -Max 256}))
# Losing this value makes all stored credentials unrecoverable.
OPEN_PINCERY_VAULT_KEY=replace-with-openssl-rand-base64-32-output

# --- Sandbox enforcement mode (optional, v9 / AC-73) -----------------------
# Controls the Zerobox tool sandbox (AC-53). Default: enforce.
#   enforce  — full sandbox; policy violations block the tool call (SAFE).
#   audit    — policy engine runs but emits `sandbox_would_block` events
#              instead of blocking. Use for one week during v9 upgrade to
#              surface allowlist gaps, then flip back to `enforce`.
#   disabled — sandbox is bypassed entirely. REQUIRES the paired
#              OPEN_PINCERY_ALLOW_UNSAFE=true below. Never use in
#              production; a stderr warning is emitted every 60s while
#              disabled. The sandbox is the primary boundary between
#              agent-emitted shell commands and your host.
# OPEN_PINCERY_SANDBOX_MODE=enforce

# --- Unsafe sandbox bypass opt-in (v9 / AC-73) -----------------------------
# Required companion to OPEN_PINCERY_SANDBOX_MODE=disabled. Must be the
# literal string `true`. Any other value (including unset, `false`, `1`,
# `yes`) refuses the bypass and fails startup. Also required companion to
# OPEN_PINCERY_SANDBOX_FLOOR=relaxed below.
# OPEN_PINCERY_ALLOW_UNSAFE=true

# --- Kernel ABI floor opt-out (optional, v9 / AC-84) -----------------------
# Controls the startup preflight that asserts the host kernel meets the v9
# sandbox floor (Landlock ABI >= 6 on Linux >= 6.7, seccomp-bpf, cgroup v2,
# unprivileged userns or root, bubblewrap >= 0.8.0). Default: strict.
#   strict   — enforce the full floor. Older kernels fail startup (SAFE).
#   relaxed  — downgrade the Landlock requirement from ABI 6 to ABI 1
#              (Linux >= 5.13). All other preflight checks stay mandatory.
#              REQUIRES the paired OPEN_PINCERY_ALLOW_UNSAFE=true above.
#              Emits a `sandbox_floor_relaxed` warning at startup.
# OPEN_PINCERY_SANDBOX_FLOOR=strict

# --- Audit-chain integrity floor (optional, v9 / AC-78) --------------------
# Controls the startup preflight that walks every agent's per-agent SHA-256
# event hash chain. Default: strict.
#   strict   — refuse to boot (exit code 5) if any agent's chain is broken.
#              Operators must investigate via `pcy audit verify --agent <id>`
#              before restarting. SAFE.
#   relaxed  — log the broken chain, emit one `audit_chain_floor_relaxed`
#              event per affected agent, then continue boot. REQUIRES the
#              paired OPEN_PINCERY_ALLOW_UNSAFE=true above. Use only during
#              forensic recovery; switch back to strict after restoring
#              integrity.
# OPEN_PINCERY_AUDIT_CHAIN_FLOOR=strict

# --- Sandbox process identity (optional, v9 / AC-86) -----------------------
# Every bwrap sandbox process runs as nobody:nogroup by default and drops all
# Linux capabilities. Override only when your deployment requires a different
# non-root identity inside the sandbox. UID/GID 0 require
# OPEN_PINCERY_ALLOW_UNSAFE=true and are refused by default.
# OPEN_PINCERY_SANDBOX_UID=65534
# OPEN_PINCERY_SANDBOX_GID=65534

# ============================================================================
# LLM provider (REQUIRED)
# ============================================================================
# Default: OpenRouter (one key, many models). To use OpenAI directly, comment
# these four lines and uncomment the OpenAI block below.

LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-api-key-here
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_MAINTENANCE_MODEL=anthropic/claude-sonnet-4-20250514

# --- OpenAI alternative (commented) ----------------------------------------
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-api-key-here
# LLM_MODEL=gpt-4o
# LLM_MAINTENANCE_MODEL=gpt-4o

# --- LLM pricing in USD per million tokens (v4 budget cap) -----------------
# Used to compute cost_usd for every LLM call. Update per your model's pricing.
LLM_PRICE_INPUT_PER_MTOK=3.0
LLM_PRICE_OUTPUT_PER_MTOK=15.0
LLM_MAINTENANCE_PRICE_INPUT_PER_MTOK=3.0
LLM_MAINTENANCE_PRICE_OUTPUT_PER_MTOK=15.0

# ============================================================================
# Observability (all optional)
# ============================================================================
# Structured JSON logs (one object per line) for log pipelines. Unset = human.
# LOG_FORMAT=json

# Prometheus /metrics endpoint on its own port. Unset = metrics disabled.
# METRICS_ADDR=127.0.0.1:9090

# Optional Landlock audit-log fallback path for AC-88. When unset, Open Pincery
# checks /var/log/audit/audit.log after shell tool calls and emits a one-time
# audit_log_unavailable warning if the source cannot be read. Set this when
# auditd/journald writes Landlock denial records somewhere else.
# OPEN_PINCERY_LANDLOCK_AUDIT_LOG=/var/log/audit/audit.log

# Standard Rust log filter.
RUST_LOG=open_pincery=info

# ============================================================================
# Runtime tunables (all optional — defaults are usually correct)
# ============================================================================
# MAX_PROMPT_CHARS=100000
# ITERATION_CAP=50
# AC-79: per-wake cap on consecutive schema-invalid LLM tool-call
# responses before the wake terminates with FailureAuditPending.
# Operators may tighten but not silently disable; 0 is rejected.
# OPEN_PINCERY_SCHEMA_INVALID_RETRY_CAP=3
# AC-79: per-wake cap on the number of tool calls that may be
# dispatched within a single wake. Independent of ITERATION_CAP
# (different quantities). On exhaustion the wake emits
# tool_call_rate_limit_exceeded once and terminates with
# FailureAuditPending. Operators may tighten but not silently
# disable; 0 is rejected.
# OPEN_PINCERY_TOOL_CALL_RATE_LIMIT_PER_WAKE=32
# STALE_WAKE_HOURS=2
# WAKE_SUMMARY_LIMIT=20
# EVENT_WINDOW_LIMIT=200

# ============================================================================
# pcy CLI (optional — only if you run pcy outside the server container)
# ============================================================================
# OPEN_PINCERY_URL=http://localhost:8080
# OPEN_PINCERY_TOKEN=paste-session-token-from-pcy-login
# PCY_CONFIG_PATH=~/.config/open-pincery/pcy.toml
